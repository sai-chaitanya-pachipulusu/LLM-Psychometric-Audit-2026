# ─────────────────────────────────────────────────────────
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────

# OpenAI (for live LLM scoring)
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# Set to "mock" to run without API calls (default)
# Set to "live" to call OpenAI API
SCORING_MODE=mock

# Kaggle (for ASAP 2.0 dataset auto-download)
# Get your token at: https://www.kaggle.com/settings/account
# Also place kaggle.json at ~/.kaggle/kaggle.json
KAGGLE_USERNAME=your-username
KAGGLE_KEY=your-kaggle-key